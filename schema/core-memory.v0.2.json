{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ltm-cli.dev/schema/core-memory.v0.2.json",
  "title": "Core Memory Packet v0.2",
  "description": "Portable, model-agnostic record of work-session intent. Additive over v0.1: parent_id, success_criteria, decisions[].consequences, methods[], attempts[].confidence.",
  "type": "object",
  "required": ["ltm_version", "id", "created_at", "goal", "next_step"],
  "additionalProperties": false,
  "properties": {
    "ltm_version": {
      "type": "string",
      "const": "0.2"
    },
    "id": {
      "type": "string",
      "minLength": 10,
      "maxLength": 64
    },
    "parent_id": {
      "type": "string",
      "minLength": 10,
      "maxLength": 64,
      "description": "Previous packet in the same work thread. Forms a single-parent DAG."
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "maxLength": 128 },
        "ref":  { "type": "string", "maxLength": 256 }
      }
    },
    "goal": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "success_criteria": {
      "type": "array",
      "items": { "type": "string", "maxLength": 1024 },
      "maxItems": 16,
      "description": "Observable done-conditions. Anchors the agent; reduces churn on vague goals."
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string", "maxLength": 1024 },
      "maxItems": 32
    },
    "decisions": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "required": ["what", "why"],
        "additionalProperties": false,
        "properties": {
          "what":         { "type": "string", "maxLength": 1024 },
          "why":          { "type": "string", "maxLength": 1024 },
          "consequences": { "type": "string", "maxLength": 1024, "description": "What this decision precludes or implies downstream. ADR-style." },
          "locked":       { "type": "boolean" }
        }
      }
    },
    "methods": {
      "type": "array",
      "maxItems": 32,
      "description": "Reusable procedural knowledge — named recipes that worked.",
      "items": {
        "type": "object",
        "required": ["name", "when_applicable", "how"],
        "additionalProperties": false,
        "properties": {
          "name":            { "type": "string", "maxLength": 128, "pattern": "^[a-z0-9][a-z0-9-]{0,127}$" },
          "when_applicable": { "type": "string", "maxLength": 1024 },
          "how":             { "type": "string", "maxLength": 2048 }
        }
      }
    },
    "attempts": {
      "type": "array",
      "maxItems": 64,
      "items": {
        "type": "object",
        "required": ["tried", "outcome"],
        "additionalProperties": false,
        "properties": {
          "tried":      { "type": "string", "maxLength": 1024 },
          "outcome":    { "type": "string", "enum": ["succeeded", "failed", "partial"] },
          "learned":    { "type": "string", "maxLength": 1024 },
          "confidence": { "type": "string", "enum": ["low", "medium", "high"], "description": "Author's confidence that this attempt's outcome is final." }
        }
      }
    },
    "open_questions": {
      "type": "array",
      "items": { "type": "string", "maxLength": 1024 },
      "maxItems": 32
    },
    "next_step": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]{0,31}$"
      },
      "maxItems": 16
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "author_model":  { "type": "string", "maxLength": 128 },
        "author_human":  { "type": "string", "maxLength": 128 },
        "source_hash":   { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "confidence":    { "type": "string", "enum": ["low", "medium", "high"] }
      }
    }
  }
}
